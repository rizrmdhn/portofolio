{
  "name": "@portofolio/types",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    "./*": {
      "types": "./src/*.ts",
      "default": "./src/*.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "clean": "git clean -xdf .cache .turbo dist node_modules",
    "dev": "tsc",
    "lint": "eslint",
    "lint:fix": "eslint --fix",
    "typecheck": "tsc --noEmit --emitDeclarationOnly false"
  },
  "devDependencies": {
    "@portofolio/config": "workspace:*",
    "type-fest": "^5.6.0",
    "typescript": "catalog:"
  },
  "dependencies": {
    "@portofolio/db": "workspace:*"
  }
}
