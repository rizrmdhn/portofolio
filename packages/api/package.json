{
  "name": "@portofolio/api",
  "type": "module",
  "exports": {
    ".": {
      "default": "./src/index.ts"
    },
    "./*": {
      "default": "./src/*.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "clean": "git clean -xdf .cache .turbo dist node_modules",
    "dev": "tsc",
    "lint": "eslint",
    "lint:fix": "eslint --fix",
    "typecheck": "tsc --noEmit --emitDeclarationOnly false"
  },
  "dependencies": {
    "@portofolio/errors": "workspace:*",
    "@portofolio/auth": "workspace:*",
    "@portofolio/db": "workspace:*",
    "@portofolio/schema": "workspace:*",
    "@portofolio/env": "workspace:*",
    "@portofolio/queries": "workspace:*",
    "@portofolio/utils": "workspace:*",
    "@portofolio/resume": "workspace:*",
    "@portofolio/uploadthing": "workspace:*",
    "@portofolio/cache": "workspace:*",
    "@portofolio/constants": "workspace:*",
    "@trpc/client": "catalog:",
    "@trpc/server": "catalog:",
    "dotenv": "catalog:",
    "zod": "catalog:",
    "superjson": "catalog:",
    "@node-rs/argon2": "catalog:",
    "uuid": "catalog:"
  },
  "devDependencies": {
    "@portofolio/config": "workspace:*",
    "@types/node": "catalog:",
    "typescript": "catalog:"
  }
}
