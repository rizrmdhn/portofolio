{
  "name": "portofolio",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "type": "module",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "clean": "turbo clean",
    "lint": "turbo lint",
    "typecheck": "turbo typecheck",
    "check-types": "turbo typecheck",
    "dev:web": "turbo -F web dev",
    "db:push": "turbo -F @portofolio/db db:push",
    "db:studio": "turbo -F @portofolio/db db:studio",
    "db:generate": "turbo -F @portofolio/db db:generate",
    "db:migrate": "turbo -F @portofolio/db db:migrate",
    "db:pull": "turbo -F @portofolio/db db:pull",
    "db:seed": "turbo -F @portofolio/db db:seed",
    "db:dump": "turbo -F @portofolio/db db:dump",
    "regenerate:jwt": "node ./scripts/regenerate-jwt-secrets.js",
    "gen": "turbo gen init"
  },
  "dependencies": {
    "@portofolio/env": "workspace:*",
    "dotenv": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@portofolio/config": "workspace:*",
    "@turbo/gen": "^2.9.8",
    "@types/node": "catalog:",
    "turbo": "^2.8.12",
    "typescript": "catalog:"
  },
  "packageManager": "pnpm@10.29.2"
}
