# When adding additional environment variables, the schema in "/src/env.js"
# should be updated accordingly.

# App URL (used for server-side rendering and API calls) or when running in production
APP_URL=http://localhost:3001

# Drizzle
DATABASE_URL="your_database_url_here"

# Example:
# SERVERVAR="foo"
# NEXT_PUBLIC_CLIENTVAR="bar"

# Allowed email for login
ALLOWED_EMAIL_LOGIN="your_email_here"
ALLOWED_EMAIL_PASSWORD="your_password_here"

# Uploadthing
UPLOADTHING_TOKEN='your_uploadthing_token_here'

# CORS allowed origins (comma-separated)
CORS_ORIGIN="http://localhost:3000,http://localhost:5174"

# Better Auth
BETTER_AUTH_SECRET=your_secret_here_min_32_chars
BETTER_AUTH_URL=http://localhost:3001